{
  "name": "family_events",
  "title": "家庭日程",
  "description": "家庭成员日程事件表",
  "columns": [
    {
      "name": "_id",
      "type": "string",
      "description": "唯一标识",
      "isPrimary": true
    },
    {
      "name": "familyGroupId",
      "type": "string",
      "description": "家庭组ID",
      "isRequired": true
    },
    {
      "name": "title",
      "type": "string",
      "description": "事件标题",
      "isRequired": true
    },
    {
      "name": "description",
      "type": "string",
      "description": "事件描述"
    },
    {
      "name": "creatorId",
      "type": "string",
      "description": "创建者ID",
      "isRequired": true
    },
    {
      "name": "creatorName",
      "type": "string",
      "description": "创建者名称"
    },
    {
      "name": "creatorAvatar",
      "type": "string",
      "description": "创建者头像"
    },
    {
      "name": "startTime",
      "type": "datetime",
      "description": "开始时间",
      "isRequired": true
    },
    {
      "name": "endTime",
      "type": "datetime",
      "description": "结束时间"
    },
    {
      "name": "location",
      "type": "string",
      "description": "事件地点"
    },
    {
      "name": "color",
      "type": "string",
      "description": "事件颜色",
      "default": "#FF8B4E"
    },
    {
      "name": "isAllDay",
      "type": "boolean",
      "description": "是否全天事件",
      "default": false
    },
    {
      "name": "repeatType",
      "type": "string",
      "description": "重复类型: none/daily/weekly/monthly",
      "default": "none"
    },
    {
      "name": "repeatDays",
      "type": "string",
      "description": "重复星期几(逗号分隔)"
    },
    {
      "name": "repeatEndDate",
      "type": "datetime",
      "description": "重复结束日期"
    },
    {
      "name": "reminderMinutes",
      "type": "number",
      "description": "提醒时间(分钟)"
    },
    {
      "name": "attendees",
      "type": "string",
      "description": "参与者ID列表(JSON数组)"
    },
    {
      "name": "attendeeNames",
      "type": "string",
      "description": "参与者名称列表(JSON数组)"
    },
    {
      "name": "status",
      "type": "string",
      "description": "状态: active/completed/cancelled",
      "default": "active"
    },
    {
      "name": "createdAt",
      "type": "datetime",
      "description": "创建时间"
    },
    {
      "name": "updatedAt",
      "type": "datetime",
      "description": "更新时间"
    }
  ]
}
