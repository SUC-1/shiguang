{
  "name": "family_finance_records",
  "title": "家庭财务记录",
  "description": "记录家庭收入支出明细",
  "fields": [
    {
      "name": "familyGroupId",
      "type": "string",
      "title": "家庭组ID",
      "required": true
    },
    {
      "name": "userId",
      "type": "string",
      "title": "用户ID",
      "required": true
    },
    {
      "name": "nickname",
      "type": "string",
      "title": "用户昵称"
    },
    {
      "name": "type",
      "type": "string",
      "title": "收支类型",
      "required": true,
      "enum": ["income", "expense"]
    },
    {
      "name": "category",
      "type": "string",
      "title": "分类",
      "required": true
    },
    {
      "name": "amount",
      "type": "number",
      "title": "金额",
      "required": true
    },
    {
      "name": "description",
      "type": "string",
      "title": "描述"
    },
    {
      "name": "recordDate",
      "type": "datetime",
      "title": "记录日期",
      "required": true
    },
    {
      "name": "paymentMethod",
      "type": "string",
      "title": "支付方式",
      "enum": ["cash", "wechat", "alipay", "card", "other"]
    },
    {
      "name": "receiptImage",
      "type": "string",
      "title": "票据图片"
    },
    {
      "name": "tags",
      "type": "array",
      "title": "标签"
    },
    {
      "name": "isRecurring",
      "type": "boolean",
      "title": "是否周期性",
      "default": false
    },
    {
      "name": "recurringType",
      "type": "string",
      "title": "周期类型",
      "enum": ["daily", "weekly", "monthly", "yearly"]
    },
    {
      "name": "createdAt",
      "type": "datetime",
      "title": "创建时间",
      "default": "now()"
    },
    {
      "name": "updatedAt",
      "type": "datetime",
      "title": "更新时间",
      "default": "now()"
    }
  ]
}