{
  "name": "family_finance_records",
  "title": "家庭财务记录",
  "description": "记录家庭收支明细",
  "fields": [
    {
      "name": "familyGroupId",
      "title": "家庭组ID",
      "type": "string",
      "required": true
    },
    {
      "name": "userId",
      "title": "用户ID",
      "type": "string",
      "required": true
    },
    {
      "name": "nickname",
      "title": "用户昵称",
      "type": "string",
      "required": true
    },
    {
      "name": "type",
      "title": "类型",
      "type": "string",
      "enum": ["income", "expense"],
      "enumNames": ["收入", "支出"],
      "required": true
    },
    {
      "name": "category",
      "title": "分类",
      "type": "string",
      "required": true
    },
    {
      "name": "amount",
      "title": "金额",
      "type": "number",
      "required": true
    },
    {
      "name": "description",
      "title": "描述",
      "type": "string"
    },
    {
      "name": "recordDate",
      "title": "记录日期",
      "type": "datetime",
      "required": true
    },
    {
      "name": "paymentMethod",
      "title": "支付方式",
      "type": "string",
      "enum": ["cash", "wechat", "alipay", "bank", "other"],
      "enumNames": ["现金", "微信", "支付宝", "银行卡", "其他"]
    },
    {
      "name": "receipt",
      "title": "收据图片",
      "type": "string"
    },
    {
      "name": "status",
      "title": "状态",
      "type": "string",
      "enum": ["pending", "confirmed", "cancelled"],
      "enumNames": ["待确认", "已确认", "已取消"],
      "default": "confirmed"
    }
  ]
}
