{
  "Name": "family_task_rewards",
  "Description": "任务奖励表",
  "DbInstanceType": "FLEXDB",
  "Schema": {
    "_id": {
      "type": "string",
      "description": "奖励ID"
    },
    "familyGroupId": {
      "type": "string",
      "description": "家庭组ID"
    },
    "name": {
      "type": "string",
      "description": "奖励名称"
    },
    "description": {
      "type": "string",
      "description": "奖励描述"
    },
    "image": {
      "type": "string",
      "description": "奖励图片"
    },
    "pointsRequired": {
      "type": "number",
      "description": "所需积分"
    },
    "stock": {
      "type": "number",
      "description": "库存数量"
    },
    "category": {
      "type": "string",
      "description": "奖励类别: privilege-特权, item-物品, experience-体验"
    },
    "status": {
      "type": "string",
      "description": "状态: active-可用, inactive-已下架"
    },
    "createdAt": {
      "type": "string",
      "description": "创建时间"
    }
  }
}
