{
  "Name": "family_tasks",
  "Description": "家庭任务表",
  "DbInstanceType": "FLEXDB",
  "Schema": {
    "_id": {
      "type": "string",
      "description": "任务ID"
    },
    "familyGroupId": {
      "type": "string",
      "description": "家庭组ID"
    },
    "title": {
      "type": "string",
      "description": "任务标题"
    },
    "description": {
      "type": "string",
      "description": "任务描述"
    },
    "assigneeId": {
      "type": "string",
      "description": "执行人ID"
    },
    "assigneeName": {
      "type": "string",
      "description": "执行人名称"
    },
    "assigneeAvatar": {
      "type": "string",
      "description": "执行人头像"
    },
    "creatorId": {
      "type": "string",
      "description": "创建人ID"
    },
    "creatorName": {
      "type": "string",
      "description": "创建人名称"
    },
    "dueDate": {
      "type": "string",
      "description": "截止日期"
    },
    "status": {
      "type": "string",
      "description": "状态: pending-待处理, in_progress-进行中, completed-已完成, cancelled-已取消"
    },
    "priority": {
      "type": "string",
      "description": "优先级: low-低, medium-中, high-高"
    },
    "points": {
      "type": "number",
      "description": "奖励积分"
    },
    "completedAt": {
      "type": "string",
      "description": "完成时间"
    },
    "createdAt": {
      "type": "string",
      "description": "创建时间"
    },
    "updatedAt": {
      "type": "string",
      "description": "更新时间"
    }
  }
}
